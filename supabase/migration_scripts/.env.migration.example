# MongoDB source
MONGO_URI=mongodb://user:password@host:27017/your_database_name
MONGO_DB_NAME=your_database_name

# Supabase destination
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: default password for migrated users (they should reset via email)
MIGRATED_USER_DEFAULT_PASSWORD=ChangeMe2024!
